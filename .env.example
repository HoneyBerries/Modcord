# PostgreSQL Database Configuration
# Copy this file to .env and fill in your actual database password.
# The .env file should NOT be committed to version control.

# PostgreSQL database password
# Required: Set this environment variable before running the bot
MODCORD_DB_PASSWORD=your_secure_database_password_here

# Discord Bot Token (optional - can also be set separately)
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

